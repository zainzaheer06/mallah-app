# =============================================================================
# Mallah Backend — Environment Configuration
# Copy this file to .env and fill in real values
# =============================================================================

# --- App ---
APP_NAME=Mallah API
APP_ENV=development               # development | staging | production
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mallah
POSTGRES_USER=mallah
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://mallah:CHANGE_ME@localhost:5432/mallah
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# --- Firebase (Phase 1.5 if creds delayed) ---
# Path to service account JSON, OR paste full JSON in FIREBASE_CREDENTIALS_JSON
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@mallah.app
EMAIL_FROM_NAME=Mallah

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Rate Limit ---
RATE_LIMIT_PER_IP_PER_MINUTE=60
RATE_LIMIT_PER_USER_PER_MINUTE=300

# --- Sentry ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Ingest auth ---
# Shared secret for the scraping team to authenticate against /ingest endpoints
INGEST_API_KEY=CHANGE_ME_INGEST_SHARED_SECRET

# --- Admin bootstrap ---
# Used once on first run to create the initial admin user
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
